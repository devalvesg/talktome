# ──────────────────────────────────────────────────────────────
# Obsidian vault (docs/) — arquivos locais/pessoais
# ──────────────────────────────────────────────────────────────
# Layout da janela e workspaces presets mudam por pessoa/sessão,
# causando conflito em quase todo push se forem commitados.
docs/.obsidian/workspace.json
docs/.obsidian/workspace-mobile.json
docs/.obsidian/workspaces.json

# Cache local do Obsidian (regenerado automaticamente).
docs/.obsidian/cache/
docs/.obsidian/file-recovery/

# Salvaguarda: se alguém abrir docs/.obsidian/ como vault por
# engano no Obsidian, ele cria um vault aninhado dentro dele.
docs/.obsidian/.obsidian/

# ──────────────────────────────────────────────────────────────
# OS / editores
# ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# ──────────────────────────────────────────────────────────────
# App (Vite + React + TS)
# ──────────────────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
.vite/
*.local

# Variáveis de ambiente (segredos / config por máquina)
.env
.env.*
!.env.example

# Logs e cache de build
logs/
*.log
npm-debug.log*
.eslintcache
*.tsbuildinfo
.vercel/
